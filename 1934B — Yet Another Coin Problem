void mahedi_solve_this_prb()
{
    int n; cin>>n;
    int ans=1e9;
 
    for(int one=0;one<=2;one++)
    {
        for(int three=0;three<=1;three++)
        {
            for(int six=0;six<=4;six++)
            {
                for(int ten=0;ten<=2;ten++)
                {
                    int sum=one*1+three*3+six*6+ten*10;
                    int remain=n-sum;
                    if(sum<=n && remain%15==0)
                    {
                        ans=min(ans,one+three+six+ten+remain/15);
                        //cout<<ans;
                        //return;
                    }
                }
            }
        }
    }
    cout<<ans;
}
 

 
int main()
{
    //go_mahedi_go;
    int t;
    cin >> t;
    while (t--)
    {
        mahedi_solve_this_prb();
        cout<<"\n";
    }
}
