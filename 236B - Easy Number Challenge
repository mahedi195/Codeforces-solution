void mahedi_solve_this_prb()
{
    int a,b,c;
    cin>>a>>b>>c;
 
    int prod=a*b*c;
    vector<int>divisiors(prod+1,0);
 
    for(int i=1; i<=prod; i++)
    {
        for(int j=i; j<=prod; j+=i)
        {
            divisiors[j]++;
        }
    }
 
    //for(auto it:divisiors) cout<<it<<" ";
    //cout<<"\n";
 
 
    int cnt=0;
 
 
    for(int i=1; i<=a; i++)
    {
        for(int j=1; j<=b; j++)
        {
            for(int k=1; k<=c; k++)
            {
                //cout<<"val = "<<i*j*k<<"\n";
                int val=i*j*k;
                cnt+=divisiors[val];
            }
        }
    }
 
    cout<<cnt%1073741824;
}
 
 
