void mahedi_solve_this_prb()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    map<int,int>mp;
 
    for(int i=0; i<n; i++)
    {
        mp[v[i]]++;
    }
 
    //sort(v.begin(),v.end());
    int previous=-1;
    int curL=-1;
    int l=-1,r=-1;
    int mex_len=-1;
    int cnt=0;
 
 
 
    for(auto it:mp)
    {
        if(it.second>=k)
        {
            if(cnt==0)
            {
                curL=it.first;
                cnt++;
 
            }
            else if(previous+1==it.first)
            {
                cnt++;
            }
 
            else
            {
                if(cnt>mex_len)
                {
 
                    mex_len=cnt;
                    r=previous;
                    l=curL;
 
                }
                cnt=1;
                curL=it.first;
 
            }
        }
        else if(it.second<k)
        {
            if(cnt>mex_len)
            {
                mex_len=cnt;
                r=previous;
                l=curL;
 
            }
 
            cnt=0;
 
        }
 
 
 
        previous=it.first;
 
        // cout<<"ll = "<<l<<" rr = "<<r<<"\n";
 
    }
 
    //cout<<"cnt = "<<cnt<<"  mexlen = "<<mex_len<<"\n";
 
    if(cnt>mex_len)
    {
        mex_len=cnt;
        r=previous;
        l=curL;
        cnt=0;
    }
 
 
    if(l==-1) cout<<-1;
    else  cout<<l<<" "<<r;
 
 
 
 
}
 
 
