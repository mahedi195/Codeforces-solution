void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n+1,1e9);
 
    for(int i=0; i<n; i++)
    {
        int x;
        cin>>x;
        v[x]=1;
    }
 
    for(int i=1; i<=n; i++)
    {
      //  if(v[i]==1)
        //    continue;
 
        for(int d=1; d*d<=i; d++)
        {
            if(i%d==0)
            {
                int d1=d;
                int d2=i/d;
 
                v[i]=min(v[i],v[d1]+v[d2]);
            }
        }
    }
 
    for(int i=1; i<=n; i++)
    {
        if(v[i]==1e9)
            v[i]=-1;
        cout<<v[i]<<" ";
    }
 
}
 
 
