void mahedi_solve_this_prb()
{
    int a,b,x;
    cin>>a>>b>>x;
 
    int ans=abs(a-b);
 
    int cnt=0;
    while(a>0 || b>0)
    {
        if(a>b)
            swap(a,b); // b big
 
        int one_add=b-a;
        ans=min(ans,cnt+one_add);
 
        b=b/x;
        cnt++;
 
 
    }
 
    ans=min(ans,cnt);
    cout<<ans;
 
}
 
 
