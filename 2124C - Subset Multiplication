void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    int lc=1;
    for(int i=1; i<n; i++)
    {
        if((v[i]%v[i-1])!=0)
        {
            // cout<<"i = "<<i<<" ";
            int gc=__gcd(v[i-1],v[i]);
            int lower=v[i-1]/gc;
            // cout<<"  gc = "<<gc<<"  lower = "<<lower<<"\n";
            lc=lcm(lc,lower);
        }
    }
 
    cout<<lc;
 
}
 
 
