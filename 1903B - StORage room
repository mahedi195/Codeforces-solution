void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    int m[n][n];
 
    int all_bit_1=pow(2,30)-1;
    vector<int>a(n,all_bit_1);
 
 
    for(int i=0; i<n; i++)
    {
        for(int j=0; j<n; j++)
        {
            cin>>m[i][j];
            if(i!=j)
            {
                a[i]=a[i]&m[i][j];
                a[j]=a[j]&m[i][j];
            }
        }
    }
 
    for(int i=0; i<n; i++)
    {
        for(int j=0; j<n; j++)
        {
 
            if(i!=j && (a[i]|a[j])!=m[i][j])
            {
                cout<<"NO";
                return;
            }
        }
    }
 
    cout<<"YES\n";
    for(auto it:a) cout<<it<<" ";
 
}
 
 
