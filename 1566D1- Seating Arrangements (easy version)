void mahedi_solve_this_prb()
{
    int n,m; cin>>n>>m;
    vector<int>v(m),ans(m,0);
    for(int i=0;i<m;i++) cin>>v[i];
    //int ans=0;
    int cnt=0;
    for(int i=1;i<m;i++)
    {
        cnt=0;
        for(int j=0;j<=i;j++)
        {
            if(v[j]<v[i]) cnt++;
        }
        ans[i]=cnt;
    }
    int res=0;
    for(int i=0;i<m;i++) res+=ans[i];
    cout<<res;
 
}
 
 
