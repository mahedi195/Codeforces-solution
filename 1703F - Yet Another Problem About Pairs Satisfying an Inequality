void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
 
    vector<pair<int,int>>vp;
    for(int i=1; i<=n; i++)
    {
        int x;
        cin>>x;
        if(x>=i) continue;
 
        vp.push_back({x,i});
    }
 
 
    sort(vp.begin(),vp.end());
 
 
    ll ans=0;
    for(int i=0; i<vp.size(); i++)
    {
        int index=vp[i].second;
        int upper=upper_bound(vp.begin(),vp.end(),make_pair(index,INT_MAX))
                  -vp.begin();
        ans+=vp.size()-upper;
 
 
    }
    cout<<ans;
 
 
}
 
 
