    {
        cout<<-1;
        return;
    }
    vector<int>v(n+1);
    //for(int i=0; i<n; i++) cin>>v[i];
 
    int gcd_1=n-k;
 
    for(int i=1;i<gcd_1;i++) v[i]=i+1;
    v[gcd_1]=1;
    for(int i=gcd_1+1;i<=n;i++) v[i]=i;
 
    for(int i=1;i<=n;i++) cout<<v[i]<<" ";
 
}
 
 
