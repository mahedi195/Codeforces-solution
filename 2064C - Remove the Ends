#include <bits/stdc++.h>
using namespace std;
using  ll=long long;
const double pi = 3.14159265358979323846;
const long long mod = 1e9 + 7;
#define oneMillion 1e6
#define go_mahedi_go ios::sync_with_stdio(false), cin.tie(nullptr)
 
void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n+1);
    for(int i=1; i<=n; i++) cin>>v[i];
 
    vector<ll>pref(n+1,0);
    for(int i=1; i<=n; i++)
    {
        if(v[i]>0)
            pref[i]=pref[i-1]+v[i];
        else pref[i]=pref[i-1];
 
    }
 
    vector<ll>suf(n+2,0);
    for(int i=n; i>=1; i--)
    {
        if(v[i]<0)
            suf[i]=suf[i+1]+abs(v[i]);
        else suf[i]=suf[i+1];
    }
 
    // cout<<"\n\n";
    // for(auto it:pref) cout<<it<<" ";
    //cout<<"\n";
    // for(auto it:suf) cout<<it<<" ";
    // cout<<"\n\n";
 
    ll ans=0;
    for(int i=0; i<=n; i++)
    {
        ans=max(ans,pref[i]+suf[i+1]);
 
    }
 
    cout<<ans;
 
 
 
}
 
 
 
int main()
{
    //go_mahedi_go;
    int t;
    cin>>t;
    //t=1;
 
    while(t--)
    {
 
        mahedi_solve_this_prb();
        cout<<"\n\n\n";
 
    }
}
