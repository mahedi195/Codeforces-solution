void sieve(int n,vector<int>&primeess)
{
    vector<int>prime(n+1,true);
    for(int i=2; i*i<=n; i++)
    {
        if(prime[i]==true)
        {
            for(int j=i*i; j<=n; j+=i)
            {
                prime[j]=false;
            }
        }
    }
 
    for(int i=2; i<=n; i++)
    {
        if(prime[i]==true)
            primeess.push_back(i);
 
    }
 
 
 
}
 
