#include <bits/stdc++.h>
using namespace std;
typedef long long int ll;
#define mod 1e9+7; 
#define go_mahedi_go ios::sync_with_stdio(false), cin.tie(nullptr);

void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
    int ans=0;
    for(int i=0; i<n;)
    {
        int j=i;
 
        while(j+1<n && v[j]*2>=v[j+1]) j++;
        //cout<<"i = "<<i<<" j = "<<j<<"\n";
        int len=j-i+1;
        ans=max(ans,len);
 
        i=j+1;
    }
    cout<<ans;
 
 
}

int main()
{
    //go_mahedi_go;
 
    int t;
    t=1;
    while (t--)
    {
        mahedi_solve_this_prb();
        cout<<"\n";
    }
}
