int favor1(string s)
{
 
    int score1=0,score2=0;
    int remainShot1=5,remainShot2=5;
 
 
    for(int i=0; i<10; i++)
    {
        if(i%2==0)
        {
            remainShot1--;
            if(s[i]=='1' || s[i]=='?') score1++;
        }
        else if(i%2==1)
        {
            remainShot2--;
            if(s[i]=='1') score2++;
        }
 
        if(score1>score2+remainShot2) return i+1;
        if(score2>score1+remainShot1) return i+1;
    }
    return 10;
}
 
 
 
