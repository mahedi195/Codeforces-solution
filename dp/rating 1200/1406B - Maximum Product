#include <bits/stdc++.h>
using namespace std;
typedef long long int ll;
#define mod 1e9+7;
#define go_mahedi_go ios::sync_with_stdio(false), cin.tie(nullptr);

void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<ll>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    sort(v.begin(),v.end());
 
    ll ans1=v[n-1]*v[n-2]*v[n-3]*v[n-4]*v[n-5];
    ll ans2=v[0]*v[1]*v[n-1]*v[n-2]*v[n-3];
    ll ans3=v[0]*v[1]*v[2]*v[3]*v[n-1];
 
    cout<<max({ans1,ans2,ans3});
 
}


int main()
{
    //go_mahedi_go;
    int t;
    cin >> t;
    //t=1;
    while (t--)
    {
        mahedi_solve_this_prb();
        cout<<"\n";
    }
}
