bool isprime(ll n)
{
    if(n<=3) return true;
    else if (n%2==0) return false;
 
    for(ll i=3; i*i<=n; i+=2)
    {
        if(n%i==0) return false;
    }
    return true;
 
}
 
 
 
 
void mahedi_solve_this_prb()
{
 
    ll n;
    cin>>n;
 
    if(n%2==0)
    {
        cout<<n/2;
        return;
    }
    ll cnt=0;
    while(n>=0)
    {
        //   cout<<"n = "<<n<<"\n";
        if(n==0)
        {
            cout<<cnt;
            return;
        }
        if(isprime(n))
        {
            cnt++;
            cout<<cnt;
            return;
        }
        else
        {
            if(n%2==0)
            {
                ll times=n/2;
                n-=2*times;
                cnt+=times;
                // cout<<" ---\n";
            }
            else
            {
                for(int i=3; i<=n*n; i++)
                {
                    if(n%i==0)
                    {
                        // cout<<"n = "<<n<<" ";
                        //  cout<<"i = "<<i<<" ";
                        n-=i;
                        //cout<<"n = "<<n<<"\n";
                        cnt++;
                        break;
                    }
                }
                //  cnt++;
            }
        }
    }
}
 
 
