void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>permutation(n);
    int i=n-1;
    while(i>=0)
    {
        int root=ceil(sqrt(i));
        int sq=root*root;
        //cout<<"ro = "<<root<<"  sq= "<<sq<<"  ";
        int block_start_ind=sq-i;
        int j=block_start_ind;
        //cout<<"j = "<<j<<"\n";
        for( ; j<=i; j++)
            permutation[j]=sq-j;

        i=block_start_ind-1;
    }

    for(int i=0; i<n; i++) cout<<permutation[i]<<" ";


}






