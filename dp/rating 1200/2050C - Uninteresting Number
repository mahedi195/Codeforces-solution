        int x=n[i]-'0';
        if(x==2) cnt2++;
        else if(x==3) cnt3++;
        sum+=x;
 
    }
    //cout<<cnt2<<"  --- "<<cnt3<<"\n";
 
    bool ans=false;
    for(int i=0; i<=cnt2; i++) //2
    {
        for(int j=0; j<=cnt3; j++)//3
        {
            int newSum=sum+2*i+6*j;
            if(newSum%9==0)
            {
                //ans=true;
