void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    vector<int>v1;
    int x=v[0];
    for(int i=1; i<n; i++)
    {
        if(x>0 && v[i]>0) x=max(x,v[i]);
        else if(x<0 && v[i]<0) x=max(x,v[i]);
        else
 
            if((x>0 && v[i]<0)||(x<0 && v[i]>0))
            {
                v1.push_back(x);
                x=v[i];
            }
            else if(x<0 && v[i]>0)
            {
                v1.push_back(x);
                x=v[i];
            }
    }
    v1.push_back(x);
 
    ll sum=0;
    for(auto it:v1) sum+=(ll)it;
    cout<<sum;
}
 

