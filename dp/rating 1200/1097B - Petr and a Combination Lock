void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    for(int i=0; i<(1<<n); i++)
    {
        int sum=0;
 
        for(int j=0; j<n; j++)
        {
            if(((i>>j) &1 )==1)
                sum+=v[j];
            else sum-=v[j];
 
        }
        if(sum>=0 && sum%360==0)
        {
            cout<<"YES";
            return;
        }
 
    }
    cout<<"NO";
 
}


