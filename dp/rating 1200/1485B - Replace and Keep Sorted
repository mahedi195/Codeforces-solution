void mahedi_solve_this_prb()
{
    int n,q,k;
    cin>>n>>q>>k;
    vector<int>v(n);

    for(int i=0; i<n; i++) cin>>v[i];
    vector<int>gap(n,0);
    for(int i=0; i<n; i++) gap[i]=v[i]-v[i-1]-1;

    vector<ll>prefixSum(n,0);
    for(int i=1; i<n; i++) prefixSum[i]=prefixSum[i-1]+gap[i];

    while(q--)
    {
        int l,r;
        cin>>l>>r;

        ll ans=0;

        ans+=v[l-1]-1;
        ans+=2*(prefixSum[r-1]-prefixSum[l-1]);
        ans+=k-v[r-1];

        cout<<ans<<"\n";

    }


}



