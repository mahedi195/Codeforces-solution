#include <bits/stdc++.h>
using namespace std;
typedef long long int ll;
const long long mod=1e9+7;

void solve()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    sort(v.begin(),v.end());
 
    for(int i=0; !v.empty(); )
    {
        if(v[0]!=v[1])
        {
            cout<<"NO";
            return;
        }
 
        else
        {
            int x=v[0];
            v.erase(v.begin()+0);
            v.erase(v.begin()+0);
            int j=0;
            // for(auto it:v) cout<<it<<" - ";
            // cout<<"\n";
            while(j<v.size() && v[j]==x)
            {
                v[j]++;
                j++;
            }
        }
 
        // for(auto it:v) cout<<it<<" ";
        //cout<<"\n";
    }
 
    cout<<"YES";
}
 
int main()
{
    int t;
    cin >> t;
    while (t--)
    {
        solve();
        cout<<"\n";
    }
}
