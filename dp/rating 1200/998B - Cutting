#include <bits/stdc++.h>
using namespace std;
typedef long long int ll;
#define mod 1e9+7;
#define go_mahedi_go ios::sync_with_stdio(false), cin.tie(nullptr);
 
void mahedi_solve_this_prb()
{
    int n,bitcoin;
    cin>>n>>bitcoin;
 
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    int ans=0;
    int odd=0,even=0;
 
    vector<int>diff;
 
    for(int i=0;i<n-1;i++)
    {
        if(v[i]%2==1) odd++;
        else even++;
 
        if(odd==even)
        {
            int d=abs(v[i+1]-v[i]);
            odd=0;
            even=0;
            diff.push_back(d);
        }
    }
 
    sort(diff.begin(),diff.end());
 
    int sum=0;
    int cnt=0;
    for(auto it:diff)
    {
        sum+=it;
        if(sum>bitcoin)
        {
            cout<<cnt;
            return;
        }
        cnt++;
 
    }
    cout<<cnt;
 
}
 

int main()
{
    //go_mahedi_go;
 
    int t;
    t=1;
    while (t--)
    {
        mahedi_solve_this_prb();
        cout<<"\n";
    }
}
