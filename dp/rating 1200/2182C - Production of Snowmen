void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>a(n),b(n),c(n);
    for(int i=0; i<n; i++) cin>>a[i];
    for(int i=0; i<n; i++) cin>>b[i];
    for(int i=0; i<n; i++) cin>>c[i];
 
    ll ab=0;
    for(int i=0;i<n;i++)
    {
        bool ok=true;
        for(int j=0;j<n;j++)
        {
            int partner=(i+j)%n;
            if(a[j]>=b[partner])
            {
                ok=false;
                break;
            }
 
        }
        if(ok) ab++;
    }
 
 
    ll bc=0;
    for(int i=0;i<n;i++)
    {
        bool ok=true;
        for(int j=0;j<n;j++)
        {
            int partner=(i+j)%n;
            if(b[j]>=c[partner])
            {
                ok=false;
                break;
            }
 
        }
        if(ok) bc++;
    }
 
    cout<<n*ab*bc;
 
}
 
 
 
