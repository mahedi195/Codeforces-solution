void mahedi_solve_this_prb()
{
    int n,l,r;
    cin>>n>>l>>r;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    sort(v.begin(),v.end());
 
    //for(auto it:v) cout<<it<<" ";
    //cout<<"\n\n";
    ll ans=0;
    for(int i=0; i<n; i++)
    {
        int left=l-v[i];
        int right=r-v[i];
 
        int lower=lower_bound(v.begin()+i+1,v.end(),left)
                  -v.begin();
        int upper=upper_bound(v.begin()+i+1,v.end(),right)
                  -v.begin();
 
        ans+=upper-lower;
 
 
 
    }
 
    cout<<ans;
 
}
 
 
 
