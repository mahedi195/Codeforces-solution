void mahedi_solve_this_prb()
{
    int n; cin>>n;
    vector<pair<int,int>>v;
    for(int i=0;i<n;i++)
    {
        int birth,death; cin>>birth>>death;
        v.push_back({birth,1});
        v.push_back({death,-1});
 
    }
 
    sort(v.begin(),v.end());
 
    int maxi_alive=0;
    int year=0;
    int alive=0;
    for(int i=0;i<v.size();i++)
    {
        if(v[i].second==1) alive++;
        else alive--;
 
        if(alive>maxi_alive)
        {
            maxi_alive=alive;
            year=v[i].first;
        }
    }
 
    cout<<year<<" "<<maxi_alive;
 
 
}
 
 
 
