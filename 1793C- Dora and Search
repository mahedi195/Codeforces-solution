void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
    int minnn=1,maxx=n;
 
    int i=0,j=n-1;
    int l=-1,r=-1;
    bool ans1=false,ans2=false;
    while(i<j)
    {
        //cout<<"\n\ni = "<<i<<"  j = "<<j<<"   minn = "<<minnn <<"  maxx= "<<maxx<<"\n";
        //cout<<"\nmin = "<<minnn<<"  max = "<<maxx<<"\n";
        //cout<<v[i]<<" - "<<v[j]<<"\n\n";
        ans1=false,ans2=false;
 
        if(!ans1)
        {
            //cout<<"v[i] = "<<v[i]<<"  min = "<<minnn<<" ";
            if(v[i]==minnn) i++,minnn++;
            else if(v[i]==maxx) i++,maxx--;
            else l=i,ans1=true;
        }
 
        if(!ans2)
        {
            // cout<<"v[j] = "<<v[j]<<"  min = "<<maxx<<" ";
 
            if(v[j]==minnn) j--,minnn++;
            else if(v[j]==maxx) j--,maxx--;
            else r=j,ans2=true;
        }
 
 
        if(ans1 && ans2)
        {
            cout<<l+1<<" "<<r+1;
            return;
        }
    }
    cout<<-1;
}
 
 
