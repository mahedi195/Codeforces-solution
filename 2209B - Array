void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>a(n);
    for(int i=0; i<n; i++) cin>>a[i];
 
    for(int i=0; i<n; i++)
    {
        int aiGreater=0,ajGreater=0;
        for(int j=i+1; j<n; j++)
        {
            if(a[i]>a[j]) aiGreater++;
            else if(a[i]<a[j]) ajGreater++;
        }
        cout<<max(aiGreater,ajGreater)<<" ";
    }
 
}
 
 
