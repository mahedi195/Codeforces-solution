void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    string top,bottom;
    cin>>top>>bottom;
    int pos=n;
    for(int i=0; i<n-1; i++)
    {
        if(top[i+1]>bottom[i])
        {
            pos=i+1;
            break;
        }
    }
 
    cout<<top.substr(0,pos)+bottom.substr(pos-1,n)<<"\n";
    int cnt=0;
    for(int i=pos-2; i>=0; i--)
    {
        if(top[i+1]==bottom[i])
            cnt++;
        else break;
    }
 
    cout<<cnt+1;
 
}
 
 
 
