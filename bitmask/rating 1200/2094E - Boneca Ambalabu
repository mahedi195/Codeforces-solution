void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    vector<int>cnt1(32);
    for(int i=0; i<32; i++)
    {
        int count1=0;
        for(int k=0; k<n; k++)
        {
            if(((v[k]>>i)&1)==1) count1++;
        }
        cnt1[i]=count1;
    }
 
    ll mx=0;
    for(int i=0; i<n; i++)
    {
        ll sum=0;
        for(int j=0; j<32; j++)
        {
            if(((v[i]>>j)&1)==1)
            {
                sum+=(n-cnt1[j])*(1LL<<j);//   pow(2,j);
            }
            else
            {
                sum+=cnt1[j]*(1LL<<j); //pow(2,j);
            }
 
        }
        mx=max(mx,sum);
    }
    cout<<mx;
}
 
 
