ll binary_expo(ll base, ll power)
{
    ll result=1;
    while(power)
    {
        if(power%2!=0)
        {
            result=(result*base)%mod;
            power--;
        }
        else
        {
            base=(base*base)%mod;
            power=power/2;
        }
    }

    return result%mod;

}


