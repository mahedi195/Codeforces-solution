void mahedi_solve_this_prb()
{
    ll a,b,c;
    cin>>a>>b>>c;
 
    ll sum=a+b+c;
    if(sum%2!=0)
    {
        cout<<"Impossible";
        return;
    }
 
    ll x=(a+b-c)/2;
    ll y=(b+c-a)/2;
    ll z=(a+c-b)/2;
 
    //cout<<x<" "<<y<<" "<<z;
    if(x>=0 && y>=0 && z>=0)
        cout<<x<<" "<<y<<" "<<z;
    else cout<<"Impossible";
 
 
 
 
 
}
 
 
