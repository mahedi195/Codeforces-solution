void mahedi_solve_this_prb()
{
 
    ll n;
    cin>>n;
 
    vector<bool>primes(n+1,true);
    vector<int>ans(n+1,0);
 
    int col=0;
    for(int i=2; i<=n; i++)
    {
        if(primes[i]==true)
        {
            col++;
            ans[i]=col;
 
            for(ll j=1LL*i*i; j<=n; j+=i)
            {
                primes[j]=false;
                ans[j]=col;
 
            }
        }
    }
 
    for(int i=2; i<=n; i++)
        cout<<ans[i]<<" ";
 
 
}
 
 
int main()
{
    //go_mahedi_go;
    int t;
    //cin>>t;
    t=1;
 
    while(t--)
    {
        mahedi_solve_this_prb();
        cout<<"\n\n\n";
 
    }
}
