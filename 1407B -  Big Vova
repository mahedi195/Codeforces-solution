void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
 
    vector<int>g,b;
    int mx=0,mx_index=-1;
    for(int i=0; i<n; i++)
    {
        if(v[i]>mx)
        {
            mx_index=i;
            mx=v[i];
        }
 
    }
    b.push_back(v[mx_index]);
    g.push_back(v[mx_index]);
    v.erase(v.begin()+mx_index);
 
 
    //cout<<v[mx_index];
 
    while(g.size()<n)
    {
 
 
        int mx_gcd=0;
        for(int i=0; i<v.size(); i++)
        {
 
            int gcd_val=__gcd(g.back(),v[i]);
            if(gcd_val>mx_gcd)
            {
                mx_gcd=gcd_val;
                mx_index=i;
            }
 
        }
 
        b.push_back(v[mx_index]);
        g.push_back(mx_gcd);
        v.erase(v.begin()+mx_index);
        //cout<<mx_gcd<<" .  ";
 
       // cout<<"\n";
    }
 
    for(auto it:b) cout<<it<<" ";
 
 
 
}
 
 
