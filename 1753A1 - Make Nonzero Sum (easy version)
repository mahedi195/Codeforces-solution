void mahedi_solve_this_prb()
{
    int n; cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++) cin>>v[i];
 
    if(n%2!=0)
    {
        cout<<-1;
        return;
    }
    vector<pair<int,int>>ans;
    for(int i=0;i<n;i+=2)
    {
        if(i!=n-1 && v[i]==v[i+1])
        {
            ans.push_back({i+1,i+2});
        }
        else
        {
            ans.push_back({i+1,i+1});
            ans.push_back({i+2,i+2});
        }
    }
    cout<<ans.size()<<"\n";
    for(auto it:ans)
        cout<<it.first<<" "<<it.second<<"\n";
 
}
 
