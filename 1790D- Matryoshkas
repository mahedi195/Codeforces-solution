void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    //set<int>s;
    map<int,int>mp;
    for(int i=0; i<n; i++) cin>>v[i], mp[v[i]]++;
 
        //set<int>s;
        int ans=0;
        for(auto element:mp)
        {
            int start=element.first;
 
            //if(mp[element]==0) continue;
 
            while(mp[start]>0)
            {
                int x=start;
                //cout<<"x = "<<x<<"\n";
                while(mp[x]>0)
                {
                    mp[x]--;
                    x++;
                }
                ans++;
                //cout<<"ans = "<<ans<<"\n\n";
            }
        }
        cout<<ans;
 
 
 
 
}
 
 
