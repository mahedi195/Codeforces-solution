#include <bits/stdc++.h>
using namespace std; 
using  ll=long long;
const double pi = 3.14159265358979323846;
const long long mod = 1e9 + 7;
#define oneMillion 1e6
#define go_mahedi_go ios::sync_with_stdio(false), cin.tie(nullptr)
 
void mahedi_solve_this_prb()
{
    int n,k;
    cin>>n>>k;
    vector<int>a(n),h(n);
    for(int i=0; i<n; i++) cin>>a[i];
    for(int i=0; i<n; i++) cin>>h[i];
 
    int ans=0;
    int l=0;
 
    ll fruit_sum=0;
 
    for(int r=0; r<n; r++)
    {
        if(h[r-1]%h[r]!=0)
        {
            l=r;
            fruit_sum=0;
        }
 
        fruit_sum+=a[r];
 
        if(fruit_sum>k)
        {
            fruit_sum-=a[l];
            l++;
        }
 
        ans=max(ans,r-l+1);
    }
 
 
    cout<<ans;
 
 
}
 
 
 
int main()
{
    //go_mahedi_go;
    int t;
    cin>>t;
    //t=1;
 
    while(t--)
    {
 
        mahedi_solve_this_prb();
        cout<<"\n\n\n";
 
    }
}
