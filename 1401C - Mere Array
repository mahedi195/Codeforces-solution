void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
 
    for(int i=0;i<n;i++)
        cin>>v[i];
 
    int mini=*min_element(v.begin(),v.end());
 
    vector<int>a;
 
    for(int i=0;i<n;i++)
    {
        if(v[i]%mini==0)
        {
            a.push_back(v[i]);
            v[i]=-1;
        }
    }
 
    sort(a.begin(),a.end());
 
    int j=0;
    for(int i=0;i<n;i++)
    {
        if(v[i]==-1)
        {
            v[i]=a[j];
            j++;
        }
    }
 
    if(is_sorted(v.begin(),v.end())) cout<<"YES";
    else cout<<"NO";
 
 
}
 
 
