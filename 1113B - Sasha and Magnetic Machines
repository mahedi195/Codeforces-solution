void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
 
    int sum=0;
    for(int i=0; i<n; i++)
    {
        cin>>v[i];
        sum+=v[i];
    }
 
    sort(v.begin(),v.end());
    int ans=sum;
 
    for(int i=1; i<n; i++)
    {
       // int val=v[i];
 
        for(int k=1; k*k<=v[i]; k++)
        {
            if(v[i]%k==0)
            {
 
                int sum1=sum;
                int sum2=sum;
 
                int d1=k;
                int d2=v[i]/k;
 
                sum1=sum1-v[0]-v[i]+(v[0]*d1)+(v[i]/d1);
 
                sum2=sum2-v[0]-v[i]+(v[0]*d2)+(v[i]/d2);
 
                ans=min({ans,sum1,sum2});
 
            }
        }
    }
 
    cout<<ans;
 
 
 
 
 
}
 
 
