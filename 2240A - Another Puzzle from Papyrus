void mahedi_solve_this_prb()
{
    int n,k; cin>>n>>k;
 
    int cnt=0;
    int x=1;
    while(1)
    {
        if(x*k>n)
        {
            cnt+=n/x;
            break;
        }
        n-=k*x;
        cnt+=k;
 
 
        x=x<<1;
    }
    cout<<cnt;
}
 
 
