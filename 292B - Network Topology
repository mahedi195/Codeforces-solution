void mahedi_solve_this_prb()
{
    int n,m;
    cin>>n>>m;
    int m1=m;
    vector<int>degree(n+1,0);
 
    while(m--)
    {
        int x,y;
        cin>>x>>y;
        degree[x]++;
        degree[y]++;
    }
 
    int one_times=0,two_times=0,m_times=0;
 
    //for(auto it:degree) cout<<it<<" ";
    //cout<<"\n";
    for(int i=1; i<=n; i++)
    {
        if(degree[i]==1) one_times++;
        else if(degree[i]==2) two_times++;
        else if(degree[i]==m1) m_times++;
    }
 
    //cout<<"m = "<<m_times<<"\n\n";
    if(one_times==2 && two_times==n-2) cout<<"bus topology";
    else if(one_times==0 && two_times==n) cout<<"ring topology";
    else if(one_times==n-1 && two_times==0 && m_times==1) cout<<"star topology";
    else cout<<"unknown topology";
 
 
 
}
 
 
int main()
{
    int t;
    //cin>>t;
    t=1;
    while(t--)
    {
        mahedi_solve_this_prb();
        cout<<"\n\n";
 
    }
}
