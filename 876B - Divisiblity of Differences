void mahedi_solve_this_prb()
{
    int n,k,m;
    cin>>n>>k>>m;
    vector<int>v(n);
 
    for(int i=0; i<n; i++)
        cin>>v[i];
 
    unordered_map<int,vector<int>>mp;
    for(int i=0; i<n; i++)
    {
        int r=v[i]%m;
        mp[r].push_back(v[i]);
    }
 
    for(auto it:mp)
    {
        if(it.second.size()>=k)
        {
            cout<<"Yes\n";
            for(int i=0; i<k; i++)
                cout<<it.second[i]<<" ";
            return;
        }
    }
 
    cout<<"No";
 
}
 
 
