void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
 
    map<int,int>freq;
    map<int,vector<int>>mp;
 
    for(int i=0; i<n; i++)
    {
        cin>>v[i];
        freq[v[i]]++;
        mp[v[i]].push_back(i);
    }
 
 
    for(auto it:freq)
    {
        if(it.second%it.first!=0)
        {
            cout<<-1;
            return;
        }
    }
 
    vector<int>ans(n);
 
    int val=0;
 
 
    for(auto it:mp)
    {
        int firstt=it.first;
 
        int x=0;
        for(int i=0; i<mp[firstt].size(); i++)
        {
            val++;
            int cnt=0;
            while(cnt<firstt)
            {
                int pos=mp[firstt][i];
                ans[pos]=val;
 
                i++;
                cnt++;
            }
            i--;
 
        }
    }
 
    for(auto it:ans) cout<<it<<" ";
 
}
 
 
 
