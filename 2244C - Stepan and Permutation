    int gc=__gcd(x,y);
    //cout<<"common gcd = "<<gc<<"\n\n";
    for(int i=1;i<=n;i++)
    {
      //  cout<<"group pos="<<i%gc<<"\n";
       // cout<<"target group pos="<<v[i]%gc<<"\n";
       int group_pos=i%gc;
       int target_group_pos=v[i]%gc;
        if(group_pos!=target_group_pos)
        {
             cout<<"NO";
            return;
        }
    }
 
    cout<<"YES";
 
}
 
 
 
