int divide(int &x)
{
    while(x%2==0)
        x=x/2;
    while(x%3==0)
        x=x/3;
 
    return x;
}
 
 
void check(vector<int>&v)
{
    int n=v.size();
    bool ans=true;
    for(int i=0; i<n; i++)
    {
        if(v[i]!=v[0])
        {
            //cout<<"NO";
            ans=false;
            break;
        }
    }
 
    if(ans==true) cout<<"Yes";
    else cout<<"No";
 
}
 
 
