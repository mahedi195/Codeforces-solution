void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    map<int,int>freq;
 
    for(int i=0; i<n; i++)
    {
        cin>>v[i];
        freq[v[i]]++;
    }
 
    vector<int>ans(n+1,0);
    for(int i=1;i<=n;i++)
    {
        if(freq[i]==0) continue;
 
        for(int d=i;d<=n;d+=i)
            ans[d]+=freq[i];
 
    }
 
    int mx=0;
    for(int i=1;i<=n;i++)
        mx=max(mx,ans[i]);
 
    cout<<mx;
}
 
 
