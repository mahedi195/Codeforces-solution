void mahedi_solve_this_prb()
{
    int n,k,m; cin>>n>>k>>m;
    if(k>m)
    {
        cout<<"NO";
        return;
    }
 
    vector<int>ans(n+1,1);
    int minimum_val=m-(k-1);
    //cout<<"minimum_val = "<<minimum_val<<"\n";
    for(int i=k;i<=n;i+=k)
        ans[i]=minimum_val;
    cout<<"YES\n";
    for(int i=1;i<=n;i++)
        cout<<ans[i]<<" ";
 
}
 
