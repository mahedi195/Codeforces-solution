void mahedi_solve_this_prb()
{
    int n,m;
    cin>>n>>m;
    vector<ll>x(n);
    for(int i=0; i<n; i++) cin>>x[i];
    vector<ll>p(m);
    for(int i=0; i<m; i++) cin>>p[i];
 
 
    vector<ll>diff;
    for(int i=0; i<n-1; i++)
    {
        ll d=abs(x[i]-x[i+1]);
        diff.push_back(d);
 
    }
 
    ll g=0;
    for(int i=0;i<diff.size();i++)
    {
        g=__gcd(g,diff[i]);
 
    }
 
    //cout<<"g = "<<g<<"\n";
    for(int i=0;i<m;i++)
    {
        if(g%p[i]==0)
        {
            cout<<"YES\n";
            cout<<x[0]<<" "<<i+1;
            return;
        }
    }
    cout<<"NO";
 
}
 
 
