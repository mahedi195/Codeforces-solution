void mahedi_solve_this_prb()
{
    int n,c;
    cin>>n>>c;
    vector<int>a(n),b(n);
    for(int i=0; i<n; i++) cin>>a[i];
    for(int i=0; i<n; i++) cin>>b[i];
 
    int  diff_sum=0;
    int  ans=INT_MAX;
 
    bool all_a_alue_greater=true;
    for(int i=0; i<n; i++)
    {
        if(a[i]>=b[i]) diff_sum+=a[i]-b[i];
        else if(a[i]<b[i]) all_a_alue_greater=false;
 
    }
 
    if(all_a_alue_greater) ans=min(ans,diff_sum);
 
    //if(all_a_alue_greater)
 
    sort(a.begin(),a.end());
    sort(b.begin(),b.end());
 
    int  res=0;
    bool again_all_a_alue_greater=true;
 
    for(int i=0; i<n; i++)
    {
        if(a[i]>=b[i]) res+=a[i]-b[i];
        else if(a[i]<b[i]) again_all_a_alue_greater=false;
    }
 
    if(again_all_a_alue_greater)
    {
        res+=c;
        ans=min(ans,res);
    }
 
    if(!all_a_alue_greater && !again_all_a_alue_greater)
        cout<<-1;
    else cout<<ans;
 
 
 
 
}
 
 
