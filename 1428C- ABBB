void mahedi_solve_this_prb()
{
    string s;
    cin>>s;
    //stack<char>st;
    int stack_size=0;
    for(int i=0; i<s.size(); i++)
    {
        if(s[i]=='B')
        {
            if(stack_size==0) stack_size++;
            else
                stack_size=max(0,stack_size-1);
        }
        else if(s[i]=='A') stack_size++;
    }
    cout<<stack_size;
}
 
