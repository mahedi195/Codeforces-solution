void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    map<string,int>depth;
    depth["polycarp"]=1;
    while(n--)
    {
        string s1,s2,s3;
        cin>>s1>>s2>>s3;

        transform(s1.begin(),s1.end(), s1.begin(),::tolower);
        transform(s3.begin(),s3.end(), s3.begin(),::tolower);

        depth[s1]=depth[s3]+1;

    }

    int ans=0;
    for(auto it:depth) ans=max(ans,it.second);

    cout<<ans;
}


