#include <bits/stdc++.h>
using namespace std;
typedef long long int ll;
#define mod 1e9+7;
#define go_mahedi_go ios::sync_with_stdio(false), cin.tie(nullptr);

void mahedi_solve_this_prb()
{
    int n,m; cin>>n>>m;
    vector<int>a(n),b(m);
    for(int i=0;i<n;i++) cin>>a[i];
    for(int i=0;i<m;i++) cin>>b[i];
    sort(a.begin(),a.end());
    sort(b.rbegin(),b.rend());
    ll sum=0,mx=0;
    for(int i=0;i<n;i++) sum+=abs(a[i]-b[i]);
    mx=sum;
    for(int i=n-1,j=m-1;i>=0;i--,j--)
    {
        sum-=abs(a[i]-b[i]);
        sum+=abs(a[i]-b[j]);
        mx=max(mx,sum);
    }
    cout<<mx;
}
 
int main()
{
    go_mahedi_go;
 
    int t;
    cin >> t;
    //t=1;
    while (t--)
    {
        mahedi_solve_this_prb();
        cout<<"\n";
        cout<<"\n";
    }
}
