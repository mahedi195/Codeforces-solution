void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    map<int,ll>freq;
 
    for(int i=0; i<n; i++)
    {
        cin>>v[i];
        freq[v[i]]++;
    }
    ll cnt=0;
    cnt=freq[1]*freq[2];
    for(auto it:freq)
    {
        ll x=it.second;
        ll pairr=(x*(x-1))/2;
        cnt+=pairr;
    }
    cout<<cnt;
 
}
 
 
