void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<ll>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
    int i=0,j=n-1;
    ll sum1=v[i];
    ll sum3=v[j];
 
    ll ans=0;
    while(i<j)
    {
        if(sum1==sum3)
        {
            ans=max(ans,sum1);
        }
        if(sum1<sum3)
        {
            i++;
            sum1+=v[i];
        }
        else
        {
            j--;
            sum3+=v[j];
        }
    }
    cout<<ans;
 
 
 
 
}
 
 
