void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<ll>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    if(n==1)
    {
        cout<<1;
        return;
    }
    int mx=*max_element(v.begin(),v.end());
 
    vector<ll>diff(n);
    for(int i=0; i<n; i++)
        diff[i]=mx-v[i];
    //for(auto it:diff) cout<<it<<" ";
    //cout<<"\n";
 
    ll g=diff[0];
    ll sum=diff[0];
    for(int i=1; i<n; i++)
    {
        g=__gcd(diff[i],g);
        sum+=diff[i];
 
    }
    //cout<<"g = "<<g<<"  sum = "<<sum<<"\n";
 
    set<int>s(v.begin(),v.end());
 
    ll new_number=mx-g;
    int cnt=1;
    while(s.count(new_number)==1)
    {
        new_number-=g;
        cnt++;
    }
    //cout<<"cnt = "<<cnt;
    //cout<<" g = "<<g<<"\n";
    // cout<<"new = "<<new_number<<"\n";
    ll ans=cnt;
    ans+=sum/g;
    cout<<ans;
 
 
}
 
 
