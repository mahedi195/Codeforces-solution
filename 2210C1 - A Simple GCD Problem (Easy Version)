void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n),vv(n);
    for(int i=0; i<n; i++) cin>>v[i];
    for(int i=0; i<n; i++) cin>>vv[i];

    int cnt=0;
    for(int i=1; i<n-1; i++)
    {
        int gcd_left=__gcd(v[i-1],v[i]);
        int gcd_right=__gcd(v[i],v[i+1]);
        int lcmm=lcm(gcd_left,gcd_right);
        if(lcmm<v[i]) cnt++;
    }
    if(__gcd(v[0],v[1])<v[0]) cnt++;
    if(__gcd(v[n-2],v[n-1])<v[n-1]) cnt++;

    cout<<cnt;

}


