#include <bits/stdc++.h>
using namespace std;
typedef long long int ll;
const long long mod= 1e9+7;
 
 
 
 
int main()
{
    int t;
    cin>>t;
    while(t--)
    {
        ll n;
        cin>>n;
        ll a[n];
        for(int i=0; i<n; i++) cin>>a[i];
 
        sort(a,a+n);
 
        if(a[0]>1)
        {
            cout<<"NO\n";
            continue;
        }
 
        bool ans=true;
        ll sum=0;
 
        for(int i=0; i<n-1; i++)
        {
            sum+=a[i];
            if(sum<a[i+1])
            {
                ans=false;
                break;
            }
 
 
 
 
        }
 
        cout<<((ans==true)?"YES":"NO");
 
 
 
        // cout<<"\n";
 
        cout<<"\n\n";
 
    }
}
