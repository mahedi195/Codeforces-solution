bool check(int row,int n, string top, string bottom )
{
 
    for(int i=0; i<n; i++)
    {
        if(row==0 && top[i]=='W') return false;
        if(row==1 && bottom[i]=='W') return false;
 
        if(top[i]=='B' && bottom[i]=='B')
        {
            if(row==0)
                row=1;
            else if(row==1)
                row=0;
        }
    }
    return true;
}
 
 
void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    string top,bottom;
    cin>>top>>bottom;
 
    if(check(0, n, top, bottom ) ||
            check(1, n, top, bottom ))
        cout<<"YES";
