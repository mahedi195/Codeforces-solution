void mahedi_solve_this_prb()
{
    int n; cin>>n;
    vector<string>s(n);
    map<string,int>freq;
    map<char,int>first,second;
    for(int i=0;i<n;i++)
    {
        cin>>s[i];
        freq[s[i]]++;
        first[s[i][0]]++;
        second[s[i][1]]++;
    }
    
    ll ans=0;
    for(int i=0;i<n;i++)
    {
        ans+=first[s[i][0]]-freq[s[i]];
        ans+=second[s[i][1]]-freq[s[i]];
    }
    ans=ans/2;
    cout<<ans;
 
}
 
 
 
