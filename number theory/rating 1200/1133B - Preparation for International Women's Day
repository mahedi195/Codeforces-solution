void mahedi_solve_this_prb()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
    map<int,int>rem;
    int r;
    for(int i=0; i<n; i++)
    {
        r=v[i]%k;
        rem[r]++;
    }
    // for(auto it:remainder) cout<<it.first<<" --> "<<it.second<<"\n";
    //cout<<"\n";
 
    int cnt=0;
    int need=0;
 
    for(int i=0; i<n; i++)
    {
        r=v[i]%k;
        need=(k-r)%k;
 
        if(rem[r]>0 && rem[need]>0)
        {
            if(r==need && rem[r]<2)
            continue;
 
            rem[r]--;
            rem[need]--;
            cnt++;
 
        }
    }
    cout<<cnt*2;
 
}
 
 
