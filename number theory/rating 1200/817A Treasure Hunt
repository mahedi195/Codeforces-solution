void mahedi_solve_this_prb()
{
    int x1,y1,x2,y2;
    cin>>x1>>y1>>x2>>y2;
    int x,y;
    cin>>x>>y;
 
    int dx=abs(x1-x2);
    int dy=abs(y1-y2);
 
    if(dx%x!=0 || dy%y!=0)
    {
        cout<<"NO";
        return;
    }
 
    int cntx=dx/x;
    int cnty=dy/y;
 
    if(cntx%2==0 && cnty%2==0) cout<<"YES";
    else if(cntx%2!=0 && cnty%2!=0) cout<<"YES";
    else cout<<"NO";
 
 
}
 
 
