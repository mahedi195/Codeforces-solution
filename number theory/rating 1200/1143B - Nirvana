ll product(string t)
{
    ll res=1;
    for(int i=0; i<t.size(); i++)
    {
        char ch=t[i];
        int digit=ch-'0';
        res*=digit;
    }
    return res;
}
 
 
void mahedi_solve_this_prb()
{
    string s;
    cin>>s;
    int n=s.size();
    ll ans=product(s);
    for(int i=n-2; i>=0; i--)
    {
        //cout<<"i = "<<i<<"  ";
        string t=s;
        if(t[i]=='0') continue;
        if(t[i]!='1')
            t[i]--;
        for(int j=i+1; j<n; j++) t[j]='9';
 
        ans=max(ans,product(t));
       // cout<<t<<" \n";
 
    }
    cout<<ans;
 
 
}
 
 
