void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    int cnt=0;
    for(int i=0; i<v.size()-1; i++)
    {
        if(gcd(v[i],v[i+1])!=1)
        {
            cnt++;
            v.insert(v.begin()+(i+1),1);
        }
    }
 
    cout<<cnt<<"\n";
    for(auto it:v) cout<<it<<" ";
 
 
 
 
}
 
 
