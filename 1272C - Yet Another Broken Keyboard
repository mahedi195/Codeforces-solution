void mahedi_solve_this_prb()
{
    int n,k;
    cin>>n>>k;
    string s;
    cin>>s;
 
    set<char>allowed;
    char ch;
    for(int i=0; i<k; i++)
    {
        cin>>ch;
        allowed.insert(ch);
    }
 
    ll cnt=0;
    int l=0;
 
    int i=0;
    for( i=0; i<n; i++)
    {
        if(allowed.count(s[i])==0)
        {
            ll len=(i-1)-l+1;
            l=i+1;
            cnt+=(len*(len+1))/2;
        }
    }
 
    ll len=(i-1)-l+1;
    l=i+1;
    cnt+=(len*(len+1))/2;
 
    cout<<cnt;
 
}

