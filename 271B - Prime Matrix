bool isprime(int x)
{
    if(x==1) return false;
    for(int i=2; i*i<=x; i++)
    {
        if(x%i==0)
        {
            return false;
        }
    }
    return true;
 
}
 
vector<int>make_prime()
{
    int n=1e5+5;
    vector<int>primes(n+1,true);
    //primes[0]=primes[1]=false;
 
    for(int i=2; i*i<=n; i++)
    {
        if(primes[i])
        {
            for(int j=i*i; j<=n; j+=i)
            {
                primes[j]=false;
            }
        }
    }
 
    vector<int>ans;
    for(int i=2; i<=n; i++)
    {
        if(primes[i]==true)
            ans.push_back(i);
    }
    return ans;
 
}
 
 
 
