void mahedi_solve_this_prb()
{
    int n,x,y;
    cin>>n>>x>>y;
 
    vector<int>v(n);
    map<pair<int,int>,int>freq;
    ll ans=0;
 
    for(int i=0; i<n; i++)
    {
        cin>>v[i];
        int x_equivalent=v[i]%x;
        int y_equivalent=v[i]%y;
 
        int need1=(x-v[i]%x)%x;
        int need2=v[i]%y;
 
        ans+=freq[ {need1,need2}];
 
        freq[ {x_equivalent,y_equivalent}]++;
 
 
    }
 
    cout<<ans;
 
 
 
 
}
 
 
int main()
{
    //go_mahedi_go;
    int t;
    cin>>t;
    //t=1;
 
    while(t--)
    {
        mahedi_solve_this_prb();
        cout<<"\n\n\n";
 
    }
}
