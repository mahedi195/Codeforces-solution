void mahedi_solve_this_prb()
{
    int n,m;
    cin>>n>>m;
    vector<int>k(n+1);
    for(int i=1; i<=n; i++) cin>>k[i];
    vector<int>c(m+1);
    for(int i=1; i<=m; i++) cin>>c[i];
 
    sort(k.begin(),k.end());
    sort(c.begin(),c.end());
 
    vector<int>ck(n+1);
    for(int i=1; i<=n; i++)
    {
        int x=k[i];
        ck[i]=c[x];
    }
 
 
 
    int p=1,q=1;
    ll ans=0;
    for(int i=1; i<=n; i++)
    {
 
        if(p<=m && c[p]<=ck[q])
        {
            ans+=c[p];
            p++;
        }
        else
        {
 
            ans+=ck[q];
            q++;
        }
 
 
    }
 
    cout<<ans;
 
 
 
}
 
 
