int zero_to_lastside(vector<int>v, int zero_pos,int n,int len)
{
    vector<bool>found(n,false);
    found[0]=true;
 
    int l=zero_pos-1;
    int r=zero_pos+1;
    int val;
    while(l>=0 && r<len && v[l]==v[r])
    {
 
        val=v[l];
        found[val]=true;
 
        l--;
        r++;
    }
 
    for(int i=0; i<n; i++)
    {
        if(found[i]==false)
            return i;
    }
    return n;
}
 
 
 
int two_size_zero_to_inside(vector<int>v,int first_zero_pos,int second_zero_pos,int n,int len)
{
    vector<bool>found(n,false);
    found[0]=true;
 
    int l=first_zero_pos+1;
    int r=second_zero_pos-1;
    int val;
 
    bool ok=true;
    
    for(; l<=r; l++,r--)
    {
        if(v[l]!=v[r])
        {
            ok=false;
            return 1;
        }
        val=v[l];
        found[val]=true;
 
 
    }
 
    if(ok)
    {
        l=first_zero_pos-1;
        r=second_zero_pos+1;
 
        while(l>=0 && r<len && v[l]==v[r])
        {
            val=v[l];
            found[val]=true;
 
            l--;
            r++;
 
        }
 
    }
 
 
    for(int i=0; i<n; i++)
    {
        if(found[i]==false)
            return i;
    }
    return n;
 
 
}
 
void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    int len=2*n;
    vector<int>v(len);
    for(int i=0; i<len; i++) cin>>v[i];
 
    int first_zero_pos=-1;
    for(int i=0; i<len; i++)
    {
        if(v[i]==0)
        {
            first_zero_pos=i;
            break;
        }
    }
 
 
    int second_zero_pos=-1;
    for(int i=first_zero_pos+1; i<len; i++)
    {
        if(v[i]==0)
        {
            second_zero_pos=i;
            break;
        }
    }
 
    int ans1=zero_to_lastside(v, first_zero_pos, n, len);
 
    int ans2=zero_to_lastside(v, second_zero_pos, n, len);
    int ans3=two_size_zero_to_inside(v, first_zero_pos, second_zero_pos,n, len);
 
    cout<<max({ans1,ans2,ans3});
 
}
 
 
 
