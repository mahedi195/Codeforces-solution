void divisors(int n,int m)
{
    if(n==1)
    {
        cout<<"yes";
        return;
    }
    
    int smallest_divisors=n;
    for(int i=2; i*i<=n; i++)
    {
        if(n%i==0)
        {
            smallest_divisors=i;
            break;
        }
    }
 
    if(smallest_divisors<=m) cout<<"NO";
    else cout<<"YES";
}
 
 
void mahedi_solve_this_prb()
{
    int n,m;
    cin>>n>>m;
    divisors(n,m);
}
 
 
