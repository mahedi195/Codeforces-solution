void mahedi_solve_this_prb()
{
    int n,m; cin>>n>>m;
    string x;
    unordered_set<string>s;
 
    for(int i=0;i<n;i++)
    {
        cin>>x;
        s.insert(x);
    }
    int common=0;
    for(int i=0;i<m;i++)
    {
        cin>>x;
        if(s.count(x)==1) common++;
    }
    //cout<<common<<"\n";
    int poland=n-common+ (common+1)/2;
    int enemy =m-common+(common/2);
    //cout<<poland<<" "<<enemy<<"\n";
    cout<<(poland>enemy ? "YES":"NO");
 
}
 
 
