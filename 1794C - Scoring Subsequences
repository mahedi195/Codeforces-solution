void mahedi_solve_this_prb()
{
    //cout<< cnt0(1000)<<"\n\n";
 
    int n;
    cin>>n;
 
    vector<int>v(n+1);
    for(int i=1; i<=n; i++)
        cin>>v[i];
 
    vector<int>res;
    for(int i=1; i<=n; i++)
    {
        int l=1, r=i;
        int ans=-1;
        while(l<=r)
        {
            int mid=l+(r-l)/2;
 
            if(v[mid]/(i-mid+1)>=1)
            {
                ans=mid;
                r=mid-1;
 
            }
            else l=mid+1;
        }
 
        res.push_back(i-ans+1);
    }
    for(auto it:res)
        cout<<it<<" ";
}
 
 
int main()
{
    //go_mahedi_go;
    int t;
    cin>>t;
    //t=1;
 
    while(t--)
    {
 
        mahedi_solve_this_prb();
        cout<<"\n\n\n";
 
    }
}
