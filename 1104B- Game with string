void mahedi_solve_this_prb()
{
    string s;
    cin>>s;
    stack<char>st;

    st.push(s[0]);
    int i=1;
    int turn=0;
    int n=s.size();
    while(i<n)
    {
        if(st.size()==0)
        {
            st.push(s[i]);
            i++;
            continue;
        }
        if(s[i]!=st.top())
        {
            st.push(s[i]);
        }
        else
        {
            st.pop();
            turn++;
        }
        i++;
    }

    if(turn%2==0) cout<<"No";
    else cout<<"Yes";
}




