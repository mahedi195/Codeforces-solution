void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    int cnt1=0,cnt2=0;
    for(int i=0; i<n; i++)
    {
        cin>>v[i];
        if(v[i]==1) cnt1++;
        else cnt2++;
    }
    if(cnt2>0) cout<<2<<" ", cnt2--;
 
    if(cnt1>0) cout<<1<<" ",cnt1--;
 
    while(cnt2--)
        cout<<2<<" ";
    while(cnt1--)
        cout<<1<<" ";
 
}
 
 
