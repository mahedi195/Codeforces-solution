void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    // map<int,int>freq;
    for(int i=0; i<n; i++)
        cin>>v[i];
 
    int min_ind,min_val=INT_MAX;
 
    for(int i=0; i<n; i++)
    {
        if(v[i]<min_val)
        {
            min_val=v[i];
            min_ind=i;
        }
    }
 
    cout<<n-1<<"\n";
    for(int i=0; i<n; i++)
    {
        if(i==min_ind)
            continue;
 
        int new_val=min_val+abs(min_ind-i);
        cout<<i+1<<" "<<min_ind+1<<" "<<new_val<<" "<<min_val<<"\n";
    }
 
 
}
 
 
