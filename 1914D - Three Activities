#include <bits/stdc++.h>
using namespace std;
typedef long long int ll;
#define mod 1e9+7;
 
#define go_mahedi_go ios::sync_with_stdio(false), cin.tie(nullptr);
 
void mahedi_solve_this_prb()
{
 
    int n;
    cin>>n;
    vector<pair<int,int>>a(n),b(n),c(n);
 
    //vector<int>a(n),b(n),c(n);
 
    for(int i=0; i<n; i++) cin>>a[i].first,a[i].second=i;
    for(int i=0; i<n; i++) cin>>b[i].first,b[i].second=i;
    for(int i=0; i<n; i++) cin>>c[i].first,c[i].second=i;
 
    sort(a.rbegin(),a.rend());
    sort(b.rbegin(),b.rend());
    sort(c.rbegin(),c.rend());
 
    int ans=0;
 
    for(int i=0; i<3; i++) //a
    {
        for(int j=0; j<3; j++) //b
        {
            for(int k=0; k<3; k++) //c 
            {
                if(a[i].second != b[j].second && a[i].second != c[k].second
                        && b[j].second !=c[k].second )
                    ans=max(ans,a[i].first+b[j].first +c[k].first);
            }
        }
    }
    cout<<ans;
 
}
 
 
int main()
{
    //  go_mahedi_go;
 
    int t;
    cin >> t;
    while (t--)
    {
        mahedi_solve_this_prb();
        cout<<"\n";
    }
}
