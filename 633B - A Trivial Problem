int cnt0(int n)
{
    int ct=0;
    int five=5;
 
    while(n>=five)
    {
        ct+=n/five;
        five*=5;
    }
 
    return ct;
 
 
}
 
 
void mahedi_solve_this_prb()
{
    //cout<< cnt0(1000)<<"\n\n";
 
    int n;
    cin>>n;
 
    int l=1,r=1e6;
    int left=-1;
    while(l<=r)
    {
        int mid=(l+r)/2;
        if(cnt0(mid)>=n)
        {
            left=mid;
            r=mid-1;
        }
        else l=mid+1;
    }
 
    // cout<<left<<"  --->\n";
 
    int right=-1;
    l=1,r=1e6;
    while(l<=r)
