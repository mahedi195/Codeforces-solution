int cnt_0(int n)
{
    int ct=0;
    int five=5;
 
    while(n>=five)
    {
        ct+=n/five;
        five*=5;
    }
 
    return ct;
 
}
 
 
 
int leftside_value(int n)
{
    int l=1,r=1e6;
    int ans=-1;
    while(l<=r)
    {
        int mid=(l+r)/2;
        if(cnt_0(mid)>=n)
        {
            ans=mid;
            r=mid-1;
        }
        else l=mid+1;
    }
    return ans;
 
}
 
 
 
int rightside_value(int n)
{
    int ans=-1;
    int l=1,r=1e6;
    while(l<=r)
    {
        int mid=(l+r)/2;
        if(cnt_0(mid)<=n)
        {
            ans=mid;
            l=mid+1;
 
 
           // r=mid-1;
        }
        else
        {
            //ans=mid;
            r=mid-1;
        }
       // cout<<"l = "<<l<<"  r = "<<r<<"\n";
 
    }
 
    return ans;
}
 
 
 
vector<int>totalZero(int a,int b,int n)
{
    vector<int>v;
 
    for(int i=a; i<=b; i++)
    {
        if(cnt_0(i)==n)
            v.push_back(i);
    }
 
    return v;
 
}
 
 
