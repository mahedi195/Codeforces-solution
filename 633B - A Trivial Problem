        int mid=(l+r)/2;
        if(cnt0(mid)<=n)
        {
            l=mid+1;
 
            //r=mid-1;
        }
        else
        {
            right=mid;
            r=mid-1;
        }
        //cout<<"l = "<<l<<"  r = "<<r<<"\n";
 
    }
 
    //cout<<right<<" ==> \n";
 
    //int cnt=0;
    vector<int>v;
    for(int i=left; i<=right; i++)
    {
        if(cnt0(i)==n)
