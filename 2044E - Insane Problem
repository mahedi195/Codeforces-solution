void mahedi_solve_this_prb()
{
    ll k,l1,r1,l2,r2;
    cin>>k>>l1>>r1>>l2>>r2;
 
    ll cnt=0;
 
    for(int n=0; n<=32; n++)
    {
        ll p=pow(k,n);
        ll L2=(l2+p-1)/p;
        ll left=max(l1,L2);
 
        ll R2=r2/p;
        ll right=min(r1,R2);
 
        if(left<=right)
            cnt+=right-left+1;
 
    }
 
    cout<<cnt;
 
 
 
 
 
 
}
 
 
