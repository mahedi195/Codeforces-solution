#include <bits/stdc++.h>
using namespace std;
typedef long long int ll;
#define mod 1e9+7;

#define go_mahedi_go ios::sync_with_stdio(false), cin.tie(nullptr);
 
void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
    
    sort(v.begin(),v.end());
 
    int cur_size=0;
    int groups=0;
    
    for(int i=0; i<n; i++)
    {
        cur_size++;
        if(cur_size>=v[i])
        {
            groups++;
            cur_size=0;
        }
 
    }
 
    cout<<groups;
 
}
 
int main()
{
    go_mahedi_go;
 
    int t;
    cin >> t;
    while (t--)
    {
        mahedi_solve_this_prb();
        cout<<"\n";
    }
}
