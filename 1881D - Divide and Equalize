void prime_factorization(int n,map<int,int>&mp)
{
    for(int i=2; i*i<=n; i++)
    {
        if(n%i==0)
        {
            int cnt=0;
            while(n%i==0)
            {
                n=n/i;
                cnt++;
            }
            mp[i]+=cnt;
        }
    }
 
    if(n>1) mp[n]++;
    //return mp;
}
 
 
 
