void mahedi_solve_this_prb()
{
    int n; cin>>n;
    vector<string>v(n);
    unordered_set<string>s;
 
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
        s.insert(v[i]);
    }
 
    for(int i=0;i<n;i++)
    {
        bool found=false;
 
        for(int len=1;len<v[i].size();len++)
        {
            string first=v[i].substr(0,len);
            string last=v[i].substr(len);
 
            if(s.count(first) && s.count(last))
            {
                found=true;
                break;
            }
        }
        if(found) cout<<1;
        else cout<<0;
    }
}
 
