vector<int>divisors(int n)
{
    vector<int>d;
    for(int i=1; i<=sqrt(n); i++)
    {
        if(n%i==0)
        {
            d.push_back(i);
            if(i!=n/i) d.push_back(n/i);
        }
    }
    return d;
}
 
 
