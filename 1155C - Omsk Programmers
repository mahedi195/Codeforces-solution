void mahedi_solve_this_prb()
{
    int a,b,x;
    cin>>a>>b>>x;
    int cnt=0;
    int ans=INT_MAX;
 
    while(a>0 || b>0)
    {
        if(a==b) break;
        ans=min(ans,cnt+abs(a-b));
        if(a<b)
            swap(a,b);
        a=a/x;
        cnt++;
        //ans=min(ans,cnt+abs(a-b));
 
    }
    ans=min(ans,cnt+abs(a-b));
    cout<<ans;
 
 
}
 
 
