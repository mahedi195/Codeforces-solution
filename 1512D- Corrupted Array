void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    int len=n+2;
    vector<ll>b(len);
    for(int i=0; i<len; i++) cin>>b[i];
    unordered_map<ll,int>fre;
    for(int i=0; i<len; i++) fre[b[i]]++;
    ll sum_b=accumulate(b.begin(),b.end(),0LL);
    for(int i=0; i<len; i++)
    {
        ll x=sum_b-2*b[i];
        // cout<<"\n";
        // cout<<x<<" "<<" fre x = ";
        //cout<<fre[x]<<"\n";
        if(x!=b[i] && fre[x]>0 || x==b[i] && fre[x]>1)
        {
            fre[x]--;
            fre[b[i]]--;
 
            for(int i=0; i<len; i++)
            {
                if(fre[b[i]]>0)
                {
                    cout<<b[i]<<" ";
                    fre[b[i]]--;
                }
            }
            return;
        }
    }
 
    cout<<-1;
 
}
 
 
