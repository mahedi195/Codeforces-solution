void mahedi_solve_this_prb()
{
 
    int n;
    cin>>n;
    vector<ll>v(n);
    //unordered_map<ll,ll>fre;
    //map<ll,ll>fre;
    for(int i=0; i<n; i++)
    {
        cin>>v[i];
        //fre[v[i]]++;
 
    }
    ll sum=accumulate(v.begin(),v.end(),0LL);
 
 
    ll targetSum=2*sum/n;
 
    if((2*sum)%n!=0)
    {
        cout<<0;
        return;
    }
 
    //unordered_map<ll,ll,custom_hash>fre;
    map<ll,ll>fre;
 
    ll cnt=0;
 
    for(int i=0; i<n; i++)
    {
        ll remain=targetSum-v[i];
        cnt=cnt+fre[remain];
        //if(remain==v[i]) cnt=cnt-1;
 
        fre[v[i]]++;
    }
    cout<<cnt;
}
 
 
