void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n),temp,ans;
    for(int i=0; i<n; i++) cin>>v[i];
 
    vector<bool>visited(n+1,false);
    int x=n;
 
    for(int i=n-1; i>=0; i--)
    {
        temp.push_back(v[i]);
        visited[v[i]]=true;
 
        if(v[i]==x)
        {
            while(x>=1 && visited[x]==true) x--;
            for(int i=temp.size()-1; i>=0; i--) ans.push_back(temp[i]);
            temp.clear();
        }
 
 
    }
 
    for(auto it:ans) cout<<it<<" ";
 
}
 
