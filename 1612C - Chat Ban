ll emotionnn(ll mid, ll k,ll total_row)
{
    ll emotions;
    if(mid<=k)
    {
        emotions=(mid*(mid+1))/2;
 
    }
    else
    {
        ll total_emotions=k*k;
        ll remove_row=total_row-mid;
        ll remove_emotions=(remove_row*(remove_row+1))/2;
        emotions=total_emotions-remove_emotions;
    }
    return emotions;
 
}
 
 
 
void mahedi_solve_this_prb()
{
    ll k,x;
    cin>>k>>x;
 
    ll total_row=2*k-1;
 
    ll l=1,r=total_row;
    ll ans=total_row;
 
    while(l<=r)
    {
        ll mid=l+(r-l)/2;
        ll emotions=emotionnn(mid,k,total_row);
 
        if(emotions>=x)
        {
            r=mid-1;
            ans=mid;
        }
        else
        {
            l=mid+1;
        }
 
 
 
 
 
    }
 
    cout<<ans;
 
 
 
}
 
 
