void mahedi_solve_this_prb()
{
    ll n,k;
    cin>>n>>k;
    vector<ll>v(n);
    for(int i=0; i<n; i++) cin>>v[i];

    if(k>n-1)
    {
        cout<<n;
        return;
    }

    ll win=0;
    ll cur=v[0];
    for(int i=1; i<n; i++)
    {
        if(cur>v[i])
            win++;
        else
        {
            cur=v[i];
            win=1;
        }

        if(win==k)
        {
            cout<<cur;
            return;
        }
    }

    cout<<cur;
}



