struct custom_hash
{
    static uint64_t splitmix64(uint64_t x)
    {
        x += 0x9e3779b97f4a7c15;
        x = (x ^ (x >> 30)) * 0xbf58476d1ce4e5b9;
        x = (x ^ (x >> 27)) * 0x94d049bb133111eb;
        return x ^ (x >> 31);
    }
 
    size_t operator()(const string &s) const
    {
        uint64_t h = 0;
        for(char c : s)
            h = h * 31 + c;
        return splitmix64(h);
    }
};
 
 
