void mahedi_solve_this_prb()
{
    int n; cin>>n;
    vector<int>v(n);
    int sum=0;
    for(int i=0;i<n;i++) cin>>v[i],sum+=v[i];
 
    if(sum==0)
    {
        cout<<"YES";
        return;
    }
    if(n%2!=0)
    {
        cout<<"NO";
        return;
    }
 
    sum=abs(sum);
    if(sum>2 && sum%4==0) cout<<"YES";
    else  cout<<"NO";
 
 
}
 
