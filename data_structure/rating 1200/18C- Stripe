void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
    
    vector<ll>prefixsum(n),suffixsum(n);
    
    prefixsum[0]=v[0];
    for(int i=1; i<n; i++) prefixsum[i]=prefixsum[i-1]+v[i];
    
    suffixsum[n-1]=v[n-1];
    for(int i=n-2; i>=0; i--) suffixsum[i]=suffixsum[i+1]+v[i];
    
    //for(auto it:prefixsum) cout<<it<<" ";
    //cout<<"\n";
    //for(auto it:suffixsum) cout<<it<<" ";
    // cout<<"\n";

    int ans=0;
    for(int i=0; i<n-1; i++)
    {
        if(prefixsum[i]==suffixsum[i+1]) ans++;
    }
    cout<<ans;
}




