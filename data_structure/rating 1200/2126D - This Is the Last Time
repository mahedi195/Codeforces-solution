void mahedi_solve_this_prb()
{
    int n,k;
    cin>>n>>k;
    vector<pair<int,pair<int,int>>>p(n);
    for(int i=0; i<n; i++)
        cin>>p[i].first>>p[i].second.first>>p[i].second.second;
 
    sort(p.begin(),p.end());
 
    for(int i=0; i<n; i++)
    {
        if(p[i].first>k) break;
        if(p[i].first<=k && k<=p[i].second.first)
            k=max(k,p[i].second.second);
    }
    cout<<k;
 
 
}
 
 
 
