void mahedi_solve_this_prb()
{
    string s;
    cin>>s;
    string suffixmin=s;
    int n=s.size();
    suffixmin[n-1]=s[n-1];
    for(int i=n-2; i>=0; i--)
        suffixmin[i]=min(s[i],suffixmin[i+1]);
    string ans(n,' ');
    for(int i=0; i<n; i++)
    {
        if(s[i]==suffixmin[i]) ans[i]=s[i];
        else
        {
            ans[i]=min(char(s[i]+1),'9');
        }
    }
    sort(ans.begin(),ans.end());
    cout<<ans;

}



