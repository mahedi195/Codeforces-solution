void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    set<int>seen,present;
    int ans=0;
    for(int i=0;i<n;i++)
    {
        seen.insert(v[i]);
        present.insert(v[i]);
 
        if(seen.size()==present.size())
        {
            ans++;
            present.clear();
        }
    }
    cout<<ans;
}
 
 
 
