void mahedi_solve_this_prb()
{
    int n; cin>>n;
    vector<int>w(n),h(n);
    int weight=0;
    for(int i=0;i<n;i++)
    {
        cin>>w[i]>>h[i];
        weight+=w[i];
    }
    vector<int>hh(n);
    hh=h;
    sort(h.begin(),h.end());
    for(int i=0;i<n;i++)
    {
        int ww=weight-w[i];
        int height=0;
        if(hh[i]==h[n-1]) height=h[n-2];
        else height=h[n-1];
        cout<<ww*height<<" ";
    }
 
}
 
 
