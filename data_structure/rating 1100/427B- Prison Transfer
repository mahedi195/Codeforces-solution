void mahedi_solve_this_prb()
{
    int n,t,c;
    cin>>n>>t>>c;
 
    vector<int>v(n);
    for(int i=0; i<n; i++) cin>>v[i];
 
    vector<int>segment;
    int ans=0;
 
    for(int i=0; i<n; i++)
    {
        if(v[i]>t)
        {
            if(segment.size()>=c)
            {
                ans+=segment.size()-c+1;
            }
            segment.clear();
        }
        else
        {
            segment.push_back(v[i]);
 
        }
    }
 
    if(segment.size()>=c)
    {
        ans+=segment.size()-c+1;
    }
    segment.clear();
    cout<<ans;
 
 
}
 
 
