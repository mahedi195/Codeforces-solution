#include <bits/stdc++.h>
using namespace std;
typedef long long int ll;
#define mod 1e9+7;
#define go_mahedi_go ios::sync_with_stdio(false), cin.tie(nullptr);

 
void mahedi_solve_this_prb()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++) cin>>v[i];
    priority_queue<int>pq;
    ll res=0;
    for(int i=0;i<n;i++)
    {
        if(v[i]>0)
        {
            pq.push(v[i]);
        }
        else if(v[i]==0 && pq.size()>0)
        {
            res+=(ll)pq.top();
            pq.pop();
        }
    }
    cout<<res;
 
}
 
int main()
{
    //go_mahedi_go;
 
    int t;
    cin >> t;
    //t=1;
    while (t--)
    {
        mahedi_solve_this_prb();
        cout<<"\n";
        cout<<"\n";
    }
}
