int first(vector<int>v,int n)
{
    int totalOperation;
 
    if(n%2==1) totalOperation=2*n;
    else totalOperation=4;
 
    int op=1;
    while(op<=totalOperation)
    {
        if(op%2==1)
        {
            for(int i=0; i<2*n; i+=2)
                swap(v[i],v[i+1]);
        }
 
        else
        {
            for(int i=0,j=n; i<n; i++,j++)
                swap(v[i],v[j]);
        }
 
        if(is_sorted(v.begin(),v.end()))
            return op;
 
        op++;
    }
    return -1;
 
}
 
 
 
 
int second(vector<int>v,int n)
{
    int totalOperation;
 
    if(n%2==1) totalOperation=2*n;
    else totalOperation=n;
 
    int op=1;
    while(op<=totalOperation)
    {
        if(op%2==1)
        {
            for(int i=0,j=n; i<n; i++,j++)
                swap(v[i],v[j]);
        }
 
        else
        {
            for(int i=0; i<2*n; i+=2)
                swap(v[i],v[i+1]);
        }
 
        if(is_sorted(v.begin(),v.end()))
            return op;
 
        op++;
    }
 
    return -1;
 
}
 
 
 
