void mahedi_solve_this_prb()
{
    int n,k ;
    cin>>n>>k;
 
    // int max_divisor=0;
    int ans=INT_MAX;
    for(int i=1; i*i<=n; i++)
    {
        if(n%i==0)
        {
            int d1=i;
            int d2=n/i;
 
            if(d1<=k)
                ans=min(ans,n/d1);
            if(d2<=k)
                ans=min(ans,n/d2);
 
            //  cout<<"i = "<<i<<"  "<<n/i<<"  "<<n/(n/i)<<"\n";
 
        }
 
        //cout<<"\n\n\n";
    }
 
    cout<<ans;
 
}
 
 
